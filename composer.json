{
    "name": "ermtraud/xsd-generator",
    "description": "XSD-to-PHP class generator for attribute-mapped XML DTOs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "xsd",
        "xml",
        "code-generation",
        "generator"
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/tredvermtraud/xml-runtime.git"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "ext-dom": "*",
        "ext-libxml": "*",
        "ermtraud/xml-runtime": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ermtraud\\XsdToPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ermtraud\\XsdToPhp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
